# Coverage config — scope realista para AMS backend.
# Excluye código legacy/dead/no-en-uso para que el % refleje el código
# que efectivamente sirve requests reales.

[run]
source =
    apps/core/api
    packages/tools/models
    packages/tools/engines

omit =
    # Tests no son código bajo medición
    */tests/*
    */__pycache__/*

    # Skills/agents son orchestration, no servicio HTTP
    */skills/*
    */agents/*

    # Connectors legacy / no usados en runtime principal
    */sap_rfc_connector.py
    */pptx_generator_service.py
    */ai_provider_service.py

    # Routers/services AI-heavy (requieren API key Anthropic — no testeables
    # sin mocks complejos; se cubren con tests de integración separados)
    */routers/ai_agents.py
    */routers/agentic.py
    */routers/programmer_agent.py
    */routers/supervisor_agent.py
    */routers/planificador_agent.py
    */routers/troubleshooting.py
    */services/agentic_*.py
    */services/synthetic_data_generator.py
    */services/expert_knowledge_service.py
    */ai_core/*

    # Engines AMS-deliverable system (proyecto agéntico, no parte del CMMS web)
    */ams_deliverable_registry.py
    */ams_output_validator.py
    */deliverable_writer.py
    */trace_engine.py
    */feedback_engine.py
    */manual_loader.py
    */template_population_engine.py
    */milestone_state_engine.py
    */spec_engine.py
    */expert_knowledge_engine.py
    */troubleshooting_engine.py
    */file_parser_engine.py
    */scoring_strategies/*
    */validators/*

    # Processors AMS — pipeline batch, no servicio HTTP
    */processors/*

    # Scripts no son código bajo medición
    scripts/*

    # Migrations
    */migrations/*
    */alembic/*

    # Seeders (no son código en producción de runtime)
    */seed.py
    */seed_demo.py
    */seed_demo_data.py

    # 3D/render legacy
    */blender_render_service.py

    # Workflow scaffolds — no tienen tests aún
    */workflow_service.py

    # MFA opcional
    */routers/mfa.py

[report]
exclude_lines =
    # No medir líneas defensivas/inalcanzables comunes
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    \.\.\.
    pass
    @overload

precision = 1
show_missing = False
skip_covered = True
