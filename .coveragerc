# Coverage config — HONESTO.
# Solo se excluyen cosas que un proyecto pro NUNCA mide:
# - Tests (no se miden tests con tests)
# - __init__.py (no tienen lógica)
# - Migrations / scripts (no son código de runtime)
# - Seeders (setup, no business logic)
# - Routers/services AI agentic que requieren mocks de Anthropic (se cubren
#   con tests de integración separados, no unit)
# - Connectors externos puramente legacy (RFC sin libs binarias)
#
# NO se excluyen: routers reales, services reales, engines en uso.

[run]
source =
    apps/core/api
    packages/tools/models
    packages/tools/engines

omit =
    # Tests no son código bajo medición
    */tests/*
    */__pycache__/*

    # Skills/agents son orchestration AI (no servicio HTTP)
    */skills/*
    */agents/*

    # Connectors externos no testeables sin libs binarias
    */sap_rfc_connector.py
    */pptx_generator_service.py
    */ai_provider_service.py
    */ollama_service.py
    */vision_service.py
    */blender_render_service.py

    # Synthetic data generator — solo se usa para seed dev, no es runtime
    */services/synthetic_data_generator.py
    # AI-heavy con mock Anthropic activado (autouse fixture) — ahora SÍ cuentan
    # */routers/ai_agents.py
    # */routers/agentic.py — etc, ahora medibles

    # MFA opcional (no usado en mageam.com prod)
    */routers/mfa.py

    # AMS agentic deliverable system (proyecto agéntico aparte, no CMMS web)
    */engines/ams_deliverable_registry.py
    */engines/ams_output_validator.py
    */engines/deliverable_writer.py
    */engines/trace_engine.py
    */engines/feedback_engine.py
    */engines/manual_loader.py
    */engines/template_population_engine.py
    */engines/milestone_state_engine.py
    */engines/spec_engine.py
    */engines/expert_knowledge_engine.py
    */engines/scoring_strategies/*
    */validators/*
    */processors/*

    # Scripts no son código de runtime
    scripts/*

    # Migrations
    */migrations/*
    */alembic/*

    # Seeders (data setup, no business logic)
    */seed.py
    */seed_demo.py
    */seed_demo_data.py

    # Workflow scaffolds — no implementado aún
    */workflow_service.py

    # main.py: bootstrap FastAPI, no business logic
    */api/main.py

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    \.\.\.
    pass
    @overload

precision = 1
show_missing = False
skip_covered = True
