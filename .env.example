# Plantilla de variables de entorno para AMS local/prod.
# Copiar a `.env` y rellenar. NUNCA commitear `.env` real.

# ── Core ───────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_at_least_32_chars_long_for_real_runs
LOG_LEVEL=INFO

# ── SAP integration (Strategy Pattern) ─────────────────────────────
# Valores: dry_run | mock | odata | rfc
# - dry_run : escribe payloads localmente, no llama SAP (default seguro)
# - mock    : Mock SAP S/4 corriendo en ocp-sap-mock (requiere perfil
#             with-sap-mock en docker-compose: `docker compose --profile
#             with-sap-mock up -d`)
# - odata   : SAP S/4HANA Cloud / On-Prem vía OData REST (auth APIKey o
#             OAuth2 client_credentials)
# - rfc     : SAP NW RFC SDK + pyrfc (Track B, requiere ABAP Dev Edition
#             o sistema SAP on-prem + NW RFC SDK instalado en container)
SAP_TRANSPORT=dry_run

# Mock-SAP (cuando SAP_TRANSPORT=mock; docker-compose profile with-sap-mock)
SAP_MOCK_URL=http://ocp-sap-mock:8000
SAP_MOCK_PORT=8032   # puerto host (cambiar si está en uso: 8030/8031 ya usados por nginx)

# OData S/4HANA (cuando SAP_TRANSPORT=odata)
# Modo 1: API Business Hub Sandbox (sólo APIKey)
SAP_ODATA_BASE_URL=https://sandbox.api.sap.com/s4hanacloud
SAP_ODATA_API_KEY=
# Modo 2: S/4HANA Cloud productivo (OAuth2 client_credentials)
# Cuando ambos están seteados, APIKey tiene precedencia (sandbox first).
SAP_ODATA_CLIENT_ID=
SAP_ODATA_CLIENT_SECRET=
SAP_ODATA_TOKEN_URL=          # default: {base}/sap/bc/sec/oauth2/token
SAP_ODATA_TIMEOUT=15

# ── Sentry observability (SF-702) ──────────────────────────────────
# Crear proyectos en sentry.io → copiar DSN aquí. Si quedan vacíos,
# Sentry queda en no-op silently (sin errores en consola).
SENTRY_DSN_BACKEND=
SENTRY_ENV=development
# Frontend (Vite build arg, expuesto al cliente)
VITE_SENTRY_DSN=

# ── AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
