# AMS Platform — Environment Configuration
# Copy this file to .env and fill in your values

# ── Database ──
DATABASE_URL=sqlite:///./data/ams.db

# ── AI (Anthropic Claude) ──
# Required for AI agents, troubleshooting, and predictive features
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Security ──
ADMIN_API_KEY=change-me-admin-key
API_KEY=change-me-api-key

# ── JWT Authentication ──
JWT_SECRET_KEY=change-me-jwt-secret-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
REQUIRE_AUTH=true

# ── CORS ──
CORS_ORIGINS=http://localhost:8080,https://your-domain.com

# ── Port Mapping ──
BACKEND_PORT=8000
FRONTEND_PORT=5173
NGINX_PORT=8080
NGINX_SSL_PORT=8443

# ── Logging ──
LOG_LEVEL=INFO
DEBUG=false

# ── SAP Mock Data ──
SAP_MOCK_DIR=/app/sap_mock/data

# ── Optional: Whisper Transcription ──
# OPENAI_API_KEY=sk-your-openai-key
