# Plantilla de variables de entorno para AMS local/prod.
# Copiar a `.env` y rellenar. NUNCA commitear `.env` real.

# ── Core ───────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_at_least_32_chars_long_for_real_runs
LOG_LEVEL=INFO

# ── SAP integration (Strategy Pattern) ─────────────────────────────
# Valores: dry_run | mock | odata | rfc
SAP_TRANSPORT=dry_run
# Mock-SAP (cuando SAP_TRANSPORT=mock; docker-compose profile with-sap-mock)
SAP_MOCK_URL=http://ocp-sap-mock:8000
# OData S/4HANA (cuando SAP_TRANSPORT=odata)
SAP_ODATA_BASE_URL=https://sandbox.api.sap.com/s4hanacloud
SAP_ODATA_API_KEY=
SAP_ODATA_CLIENT_ID=
SAP_ODATA_CLIENT_SECRET=

# ── Sentry observability (SF-702) ──────────────────────────────────
# Crear proyectos en sentry.io → copiar DSN aquí. Si quedan vacíos,
# Sentry queda en no-op silently (sin errores en consola).
SENTRY_DSN_BACKEND=
SENTRY_ENV=development
# Frontend (Vite build arg, expuesto al cliente)
VITE_SENTRY_DSN=

# ── AI ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
